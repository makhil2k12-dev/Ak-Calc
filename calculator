<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scientific Calculator</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .calculator {
            background: #1e1e2f;
            border-radius: 20px;
            padding: 24px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
            width: 420px;
            max-width: 95vw;
        }

        .calculator-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .calculator-title {
            color: #a0a0c0;
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .mode-toggle {
            background: #2a2a3d;
            color: #4fc3f7;
            border: 1px solid #4fc3f7;
            border-radius: 20px;
            padding: 4px 14px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            letter-spacing: 1px;
        }

        .mode-toggle:hover {
            background: #4fc3f7;
            color: #1e1e2f;
        }

        .display {
            background: #12121f;
            border-radius: 14px;
            padding: 20px;
            margin-bottom: 18px;
            min-height: 100px;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            align-items: flex-end;
            border: 1px solid #2a2a3d;
        }

        .expression {
            color: #6a6a8a;
            font-size: 16px;
            min-height: 24px;
            word-break: break-all;
            text-align: right;
            width: 100%;
            margin-bottom: 8px;
        }

        .result {
            color: #e0e0ff;
            font-size: 36px;
            font-weight: 300;
            word-break: break-all;
            text-align: right;
            width: 100%;
            transition: font-size 0.2s;
        }

        .result.small {
            font-size: 24px;
        }

        .memory-indicator {
            color: #4fc3f7;
            font-size: 11px;
            font-weight: 600;
            min-height: 16px;
            margin-bottom: 4px;
            width: 100%;
            text-align: left;
        }

        .btn-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 8px;
        }

        .btn {
            background: #2a2a3d;
            color: #c0c0e0;
            border: none;
            border-radius: 12px;
            padding: 14px 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.15s ease;
            user-select: none;
            -webkit-user-select: none;
        }

        .btn:hover {
            background: #3a3a50;
            transform: translateY(-1px);
        }

        .btn:active {
            transform: translateY(1px);
            background: #22222f;
        }

        .btn.sci {
            background: #1a1a2a;
            color: #8888aa;
            font-size: 12px;
        }

        .btn.sci:hover {
            background: #2a2a3d;
            color: #b0b0d0;
        }

        .btn.op {
            background: #2d2a40;
            color: #bb86fc;
        }

        .btn.op:hover {
            background: #3d3a55;
        }

        .btn.num {
            background: #2a2a3d;
            color: #e0e0ff;
            font-size: 18px;
        }

        .btn.num:hover {
            background: #3a3a55;
        }

        .btn.equals {
            background: linear-gradient(135deg, #4fc3f7, #0288d1);
            color: #fff;
            font-size: 20px;
            font-weight: 600;
        }

        .btn.equals:hover {
            background: linear-gradient(135deg, #6dd5fa, #0399e8);
        }

        .btn.clear {
            background: #3d1a1a;
            color: #ff6b6b;
        }

        .btn.clear:hover {
            background: #4d2a2a;
        }

        .btn.memory {
            background: #1a2a1a;
            color: #66bb6a;
            font-size: 11px;
        }

        .btn.memory:hover {
            background: #2a3a2a;
        }

        .btn.wide {
            grid-column: span 2;
        }

        @media (max-width: 440px) {
            .calculator {
                padding: 16px;
                border-radius: 16px;
            }
            .btn {
                padding: 12px 6px;
                font-size: 13px;
            }
            .btn.num {
                font-size: 16px;
            }
            .btn.sci {
                font-size: 11px;
            }
            .result {
                font-size: 28px;
            }
        }
    </style>
</head>
<body>
    <div class="calculator">
        <div class="calculator-header">
            <span class="calculator-title">Scientific Calculator</span>
            <button class="mode-toggle" id="modeToggle" title="Toggle Degrees/Radians">DEG</button>
        </div>

        <div class="display">
            <div class="memory-indicator" id="memoryIndicator"></div>
            <div class="expression" id="expression"></div>
            <div class="result" id="result">0</div>
        </div>

        <div class="btn-grid">
            <!-- Row 1: Memory -->
            <button class="btn memory" data-action="mc">MC</button>
            <button class="btn memory" data-action="mr">MR</button>
            <button class="btn memory" data-action="m+">M+</button>
            <button class="btn memory" data-action="m-">M&minus;</button>
            <button class="btn clear" data-action="clear">AC</button>

            <!-- Row 2: Scientific -->
            <button class="btn sci" data-action="sin">sin</button>
            <button class="btn sci" data-action="cos">cos</button>
            <button class="btn sci" data-action="tan">tan</button>
            <button class="btn sci" data-action="log">log</button>
            <button class="btn sci" data-action="ln">ln</button>

            <!-- Row 3: Scientific -->
            <button class="btn sci" data-action="asin">sin<sup>&minus;1</sup></button>
            <button class="btn sci" data-action="acos">cos<sup>&minus;1</sup></button>
            <button class="btn sci" data-action="atan">tan<sup>&minus;1</sup></button>
            <button class="btn sci" data-action="sqrt">&radic;</button>
            <button class="btn sci" data-action="cbrt"><sup>3</sup>&radic;</button>

            <!-- Row 4: Scientific -->
            <button class="btn sci" data-action="square">x&sup2;</button>
            <button class="btn sci" data-action="cube">x&sup3;</button>
            <button class="btn sci" data-action="power">x<sup>y</sup></button>
            <button class="btn sci" data-action="factorial">n!</button>
            <button class="btn sci" data-action="reciprocal">1/x</button>

            <!-- Row 5: Constants & Misc -->
            <button class="btn sci" data-action="pi">&pi;</button>
            <button class="btn sci" data-action="e">e</button>
            <button class="btn sci" data-action="abs">|x|</button>
            <button class="btn op" data-action="open-paren">(</button>
            <button class="btn op" data-action="close-paren">)</button>

            <!-- Row 6: 7 8 9 / backspace -->
            <button class="btn num" data-action="digit" data-value="7">7</button>
            <button class="btn num" data-action="digit" data-value="8">8</button>
            <button class="btn num" data-action="digit" data-value="9">9</button>
            <button class="btn op" data-action="operator" data-value="/">&divide;</button>
            <button class="btn clear" data-action="backspace">&larr;</button>

            <!-- Row 7: 4 5 6 * % -->
            <button class="btn num" data-action="digit" data-value="4">4</button>
            <button class="btn num" data-action="digit" data-value="5">5</button>
            <button class="btn num" data-action="digit" data-value="6">6</button>
            <button class="btn op" data-action="operator" data-value="*">&times;</button>
            <button class="btn sci" data-action="percent">%</button>

            <!-- Row 8: 1 2 3 - negate -->
            <button class="btn num" data-action="digit" data-value="1">1</button>
            <button class="btn num" data-action="digit" data-value="2">2</button>
            <button class="btn num" data-action="digit" data-value="3">3</button>
            <button class="btn op" data-action="operator" data-value="-">&minus;</button>
            <button class="btn sci" data-action="negate">&plusmn;</button>

            <!-- Row 9: 0 . = + -->
            <button class="btn num wide" data-action="digit" data-value="0">0</button>
            <button class="btn num" data-action="decimal">.</button>
            <button class="btn equals" data-action="equals">=</button>
            <button class="btn op" data-action="operator" data-value="+">+</button>
        </div>
    </div>

    <script>
        // ── State ────────────────────────────────────────────────────────
        let expression = '';
        let currentInput = '0';
        let result = null;
        let memory = 0;
        let useDegrees = true;
        let justEvaluated = false;

        // ── DOM refs ─────────────────────────────────────────────────────
        const expressionEl = document.getElementById('expression');
        const resultEl = document.getElementById('result');
        const memoryIndicatorEl = document.getElementById('memoryIndicator');
        const modeToggleEl = document.getElementById('modeToggle');

        // ── Helpers ──────────────────────────────────────────────────────
        function toRad(deg) { return deg * Math.PI / 180; }
        function toDeg(rad) { return rad * 180 / Math.PI; }

        function factorial(n) {
            if (n < 0) return NaN;
            if (n === 0 || n === 1) return 1;
            if (n > 170) return Infinity;
            if (!Number.isInteger(n)) return gamma(n + 1);
            let res = 1;
            for (let i = 2; i <= n; i++) res *= i;
            return res;
        }

        function gamma(z) {
            if (z < 0.5) {
                return Math.PI / (Math.sin(Math.PI * z) * gamma(1 - z));
            }
            z -= 1;
            const g = 7;
            const c = [
                0.99999999999980993, 676.5203681218851, -1259.1392167224028,
                771.32342877765313, -176.61502916214059, 12.507343278686905,
                -0.13857109526572012, 9.9843695780195716e-6, 1.5056327351493116e-7
            ];
            let x = c[0];
            for (let i = 1; i < g + 2; i++) {
                x += c[i] / (z + i);
            }
            const t = z + g + 0.5;
            return Math.sqrt(2 * Math.PI) * Math.pow(t, z + 0.5) * Math.exp(-t) * x;
        }

        function formatNumber(num) {
            if (num === null || num === undefined) return '0';
            if (typeof num === 'string') return num;
            if (isNaN(num)) return 'Error';
            if (!isFinite(num)) return num > 0 ? 'Infinity' : '-Infinity';
            if (Math.abs(num) > 1e15 || (Math.abs(num) < 1e-10 && num !== 0)) {
                return num.toExponential(8);
            }
            const str = parseFloat(num.toPrecision(12)).toString();
            return str;
        }

        function updateDisplay() {
            expressionEl.textContent = expression;
            const display = justEvaluated && result !== null ? formatNumber(result) : currentInput;
            resultEl.textContent = display;
            resultEl.classList.toggle('small', display.length > 12);
            memoryIndicatorEl.textContent = memory !== 0 ? 'M' : '';
        }

        function getNumericValue() {
            if (justEvaluated && result !== null) return result;
            return parseFloat(currentInput) || 0;
        }

        function setResult(val) {
            result = val;
            currentInput = formatNumber(val);
            justEvaluated = true;
            updateDisplay();
        }

        // ── Scientific functions ─────────────────────────────────────────
        function applyScientificFn(fnName) {
            const val = getNumericValue();
            let res;

            switch (fnName) {
                case 'sin':
                    res = useDegrees ? Math.sin(toRad(val)) : Math.sin(val);
                    expression = `sin(${formatNumber(val)})`;
                    break;
                case 'cos':
                    res = useDegrees ? Math.cos(toRad(val)) : Math.cos(val);
                    expression = `cos(${formatNumber(val)})`;
                    break;
                case 'tan':
                    res = useDegrees ? Math.tan(toRad(val)) : Math.tan(val);
                    expression = `tan(${formatNumber(val)})`;
                    break;
                case 'asin':
                    res = Math.asin(val);
                    if (useDegrees) res = toDeg(res);
                    expression = `sin\u207B\u00B9(${formatNumber(val)})`;
                    break;
                case 'acos':
                    res = Math.acos(val);
                    if (useDegrees) res = toDeg(res);
                    expression = `cos\u207B\u00B9(${formatNumber(val)})`;
                    break;
                case 'atan':
                    res = Math.atan(val);
                    if (useDegrees) res = toDeg(res);
                    expression = `tan\u207B\u00B9(${formatNumber(val)})`;
                    break;
                case 'log':
                    res = Math.log10(val);
                    expression = `log(${formatNumber(val)})`;
                    break;
                case 'ln':
                    res = Math.log(val);
                    expression = `ln(${formatNumber(val)})`;
                    break;
                case 'sqrt':
                    res = Math.sqrt(val);
                    expression = `\u221A(${formatNumber(val)})`;
                    break;
                case 'cbrt':
                    res = Math.cbrt(val);
                    expression = `\u221B(${formatNumber(val)})`;
                    break;
                case 'square':
                    res = val * val;
                    expression = `(${formatNumber(val)})\u00B2`;
                    break;
                case 'cube':
                    res = val * val * val;
                    expression = `(${formatNumber(val)})\u00B3`;
                    break;
                case 'factorial':
                    res = factorial(val);
                    expression = `${formatNumber(val)}!`;
                    break;
                case 'reciprocal':
                    res = val === 0 ? NaN : 1 / val;
                    expression = `1/(${formatNumber(val)})`;
                    break;
                case 'abs':
                    res = Math.abs(val);
                    expression = `|${formatNumber(val)}|`;
                    break;
                case 'percent':
                    res = val / 100;
                    expression = `${formatNumber(val)}%`;
                    break;
                default:
                    return;
            }

            if (Math.abs(res) < 1e-14 && Math.abs(res) > 0) res = 0;
            setResult(res);
        }

        // ── Arithmetic state ─────────────────────────────────────────────
        let pendingOperator = null;
        let accumulator = null;

        function clearAll() {
            expression = '';
            currentInput = '0';
            result = null;
            justEvaluated = false;
            pendingOperator = null;
            accumulator = null;
            updateDisplay();
        }

        function inputDigit(d) {
            if (justEvaluated) {
                currentInput = d;
                expression = '';
                justEvaluated = false;
            } else if (currentInput === '0' && d !== '.') {
                currentInput = d;
            } else {
                currentInput += d;
            }
            updateDisplay();
        }

        function inputDecimal() {
            if (justEvaluated) {
                currentInput = '0.';
                expression = '';
                justEvaluated = false;
            } else if (!currentInput.includes('.')) {
                currentInput += '.';
            }
            updateDisplay();
        }

        function inputOperator(op) {
            const val = getNumericValue();

            if (accumulator === null) {
                accumulator = val;
            } else if (pendingOperator && !justEvaluated) {
                accumulator = compute(accumulator, pendingOperator, val);
            } else if (pendingOperator && justEvaluated) {
                accumulator = val;
            }

            const opSymbol = { '+': ' + ', '-': ' \u2212 ', '*': ' \u00D7 ', '/': ' \u00F7 ' }[op] || ` ${op} `;

            if (justEvaluated) {
                expression = formatNumber(val) + opSymbol;
            } else {
                expression += formatNumber(val) + opSymbol;
            }

            pendingOperator = op;
            justEvaluated = false;
            currentInput = '0';
            updateDisplay();
        }

        function compute(a, op, b) {
            switch (op) {
                case '+': return a + b;
                case '-': return a - b;
                case '*': return a * b;
                case '/': return b === 0 ? NaN : a / b;
                case '**': return Math.pow(a, b);
                default: return b;
            }
        }

        function evaluate() {
            if (pendingOperator === null) {
                result = getNumericValue();
                expression = formatNumber(result) + ' =';
                justEvaluated = true;
                updateDisplay();
                return;
            }

            const val = getNumericValue();
            const res = compute(accumulator, pendingOperator, val);

            expression += formatNumber(val) + ' =';
            result = res;
            currentInput = formatNumber(res);
            justEvaluated = true;
            pendingOperator = null;
            accumulator = null;
            updateDisplay();
        }

        function inputPower() {
            const val = getNumericValue();
            accumulator = val;
            pendingOperator = '**';
            expression = formatNumber(val) + ' ^ ';
            justEvaluated = false;
            currentInput = '0';
            updateDisplay();
        }

        function handleBackspace() {
            if (justEvaluated) return;
            if (currentInput.length > 1) {
                currentInput = currentInput.slice(0, -1);
            } else {
                currentInput = '0';
            }
            updateDisplay();
        }

        function handleNegate() {
            if (justEvaluated && result !== null) {
                result = -result;
                currentInput = formatNumber(result);
            } else {
                const val = parseFloat(currentInput);
                if (val !== 0) {
                    currentInput = formatNumber(-val);
                }
            }
            updateDisplay();
        }

        // ── Parentheses support ──────────────────────────────────────────
        let parenDepth = 0;
        let parenExpr = '';
        let inParenMode = false;

        function handleOpenParen() {
            if (justEvaluated) {
                expression = '';
                currentInput = '0';
                justEvaluated = false;
                accumulator = null;
                pendingOperator = null;
            }
            parenDepth++;
            if (!inParenMode) {
                inParenMode = true;
                parenExpr = '';
            }
            parenExpr += '(';
            expression += '(';
            currentInput = '0';
            updateDisplay();
        }

        function handleCloseParen() {
            if (parenDepth <= 0) return;
            parenDepth--;
            parenExpr += currentInput + ')';
            expression += currentInput + ')';

            if (parenDepth === 0 && inParenMode) {
                try {
                    const safeExpr = parenExpr.replace(/[^0-9+\-*/().e ]/g, '');
                    const res = Function('"use strict"; return (' + safeExpr + ')')();
                    currentInput = formatNumber(res);
                    result = res;
                } catch (err) {
                    currentInput = 'Error';
                }
                inParenMode = false;
                parenExpr = '';
            }
            updateDisplay();
        }

        // ── Event handling ───────────────────────────────────────────────
        document.querySelector('.btn-grid').addEventListener('click', function (e) {
            var btn = e.target.closest('.btn');
            if (!btn) return;

            var action = btn.dataset.action;
            var value = btn.dataset.value;

            switch (action) {
                case 'digit':
                    if (inParenMode) {
                        if (currentInput === '0') currentInput = value;
                        else currentInput += value;
                        updateDisplay();
                    } else {
                        inputDigit(value);
                    }
                    break;

                case 'decimal':
                    if (inParenMode) {
                        if (!currentInput.includes('.')) currentInput += '.';
                        updateDisplay();
                    } else {
                        inputDecimal();
                    }
                    break;

                case 'operator':
                    if (inParenMode) {
                        parenExpr += currentInput + value;
                        expression += currentInput + ({ '+': '+', '-': '\u2212', '*': '\u00D7', '/': '\u00F7' }[value] || value);
                        currentInput = '0';
                        updateDisplay();
                    } else {
                        inputOperator(value);
                    }
                    break;

                case 'equals':
                    evaluate();
                    break;

                case 'clear':
                    parenDepth = 0;
                    inParenMode = false;
                    parenExpr = '';
                    clearAll();
                    break;

                case 'backspace':
                    handleBackspace();
                    break;

                case 'negate':
                    handleNegate();
                    break;

                case 'pi':
                    currentInput = Math.PI.toString();
                    if (justEvaluated) { expression = ''; justEvaluated = false; }
                    updateDisplay();
                    break;

                case 'e':
                    currentInput = Math.E.toString();
                    if (justEvaluated) { expression = ''; justEvaluated = false; }
                    updateDisplay();
                    break;

                case 'power':
                    inputPower();
                    break;

                case 'open-paren':
                    handleOpenParen();
                    break;

                case 'close-paren':
                    handleCloseParen();
                    break;

                case 'mc':
                    memory = 0;
                    updateDisplay();
                    break;

                case 'mr':
                    currentInput = formatNumber(memory);
                    if (justEvaluated) { expression = ''; justEvaluated = false; }
                    updateDisplay();
                    break;

                case 'm+':
                    memory += getNumericValue();
                    updateDisplay();
                    break;

                case 'm-':
                    memory -= getNumericValue();
                    updateDisplay();
                    break;

                case 'sin':
                case 'cos':
                case 'tan':
                case 'asin':
                case 'acos':
                case 'atan':
                case 'log':
                case 'ln':
                case 'sqrt':
                case 'cbrt':
                case 'square':
                case 'cube':
                case 'factorial':
                case 'reciprocal':
                case 'abs':
                case 'percent':
                    applyScientificFn(action);
                    break;
            }
        });

        // ── DEG / RAD toggle ─────────────────────────────────────────────
        modeToggleEl.addEventListener('click', function () {
            useDegrees = !useDegrees;
            modeToggleEl.textContent = useDegrees ? 'DEG' : 'RAD';
        });

        // ── Keyboard support ─────────────────────────────────────────────
        document.addEventListener('keydown', function (e) {
            var key = e.key;

            if (key >= '0' && key <= '9') {
                e.preventDefault();
                if (inParenMode) {
                    if (currentInput === '0') currentInput = key;
                    else currentInput += key;
                    updateDisplay();
                } else {
                    inputDigit(key);
                }
            } else if (key === '.') {
                e.preventDefault();
                inputDecimal();
            } else if (key === '+' || key === '-' || key === '*' || key === '/') {
                e.preventDefault();
                inputOperator(key);
            } else if (key === 'Enter' || key === '=') {
                e.preventDefault();
                evaluate();
            } else if (key === 'Backspace') {
                e.preventDefault();
                handleBackspace();
            } else if (key === 'Escape' || key === 'c' || key === 'C') {
                e.preventDefault();
                parenDepth = 0;
                inParenMode = false;
                parenExpr = '';
                clearAll();
            } else if (key === '(') {
                e.preventDefault();
                handleOpenParen();
            } else if (key === ')') {
                e.preventDefault();
                handleCloseParen();
            }
        });

        // ── Initial display ──────────────────────────────────────────────
        updateDisplay();
    </script>
</body>
</html>
